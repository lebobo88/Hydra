{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m hydra_core.cli doctor",
            "timeout": 20
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m hydra_core.cli squads",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__hydra-memory__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m hydra_core.cli doctor",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__executive-suite__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m hydra_core.cli doctor",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__rlm-creative__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m hydra_core.cli doctor",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__hydra-memory__write.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo postcheck",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__(executive-suite|rlm-creative)__.*output\\.write.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo postcheck",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo checkpoint-flush",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
