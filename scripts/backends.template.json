    "command": "node",
    "args": [
      "{{AIAPP_BASE}}/AgentSmith/daemon/dist/index.js"
    ]
  },
  "hydra_memory": {
    "type": "stdio",
    "command": "python",
    "args": [
      "-m",
      "mcp_servers.hydra_memory"
    ],
    "cwd": "{{HYDRA_ROOT}}",
    "env": {
      "PYTHONPATH": "{{HYDRA_ROOT}}",
      "HYDRA_EPISODIC_DB": "${USERPROFILE}/.hydra/episodic.db",
      "HYDRA_VECTOR_DIR": "${USERPROFILE}/.hydra/vectors",
      "HYDRA_MEM_FEDERATE_EIGHTS": "1",
      "HYDRA_MEM_FEDERATE_TIMEOUT": "8"
    }
  },
