{
  "pp_harness": {
    "type": "stdio",
    "command": "node",
    "args": [
      "{{AIAPP_BASE}}/pair-programmer/daemon/dist/index.js",
      "mcp"
    ]
  },
  "pp_codex": {
    "type": "stdio",
    "command": "node",
    "args": [
      "{{AIAPP_BASE}}/pair-programmer/daemon/dist/index.js",
      "mcp-codex"
    ],
    "env": {}
  },
  "pp_gemini": {
    "type": "stdio",
    "command": "node",
    "args": [
      "{{AIAPP_BASE}}/pair-programmer/daemon/dist/index.js",
